generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Booking {
  id          String      @id @default(cuid())
  name        String
  phone       String
  sessionType SessionType
  startTime   DateTime
  endTime     DateTime
  duration    Int
  notes       String?
  createdAt   DateTime    @default(now())
}

model BlockedTime {
  id        String   @id @default(cuid())
  startTime DateTime
  endTime   DateTime
  reason    String?
  createdAt DateTime @default(now())
}

enum SessionType {
  RECORDING
  MIXING
  MASTERING
  OTHER
}
